# --- Data & Large Files ---
# Ignore all data content by default
data/raw/**
data/processed/**

# Allow the directory structure (so the folders exist for the script)
!data/raw/
!data/processed/
!data/raw/**/

# Whitelist the specific metadata "Exceptions"
!data/raw/**/feature_description.csv
!data/raw/**/event_info.csv

# Keep the repository structure intact
!**/.gitkeep
!data/README.md

# Global block for other data types (keep as is)
*.parquet
*.feather
*.h5
*.pkl
*.joblib
*.npy
*.zip
*.gz

# Ensure specifically numbered telemetry CSVs are ignored 
# (This acts as a backup to the raw/**/* rule)
data/raw/**/[0-9]*.csv

# Large Archives (Zenodo downloads)
*.zip
*.7z
*.tar
*.gz
*.rar

# --- Models & Results ---
models/*
!models/.gitkeep
# Ignore the archive folder contents (for junk/old scripts)
archive/*
!archive/.gitkeep

# --- IDE & System ---
.ipynb_checkpoints/
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# --- Python Environment & Build ---
__pycache__/
*.py[cod]
*$py.class
.env
.venv
env/
venv/
build/
dist/
*.egg-info/

# --- Testing & Coverage ---
.pytest_cache/
.coverage
htmlcov/
.hypothesis/

# --- Logs & Artifacts ---
logs/*.log
*.log
data/artifacts/*
!data/artifacts/**/.gitkeep